{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Runik AI",
  "version": "0.3.0",
  "identifier": "com.runikapp.desktop",
  "build": {
    "devUrl": "https://runikapp.com/app/",
    "frontendDist": "https://runikapp.com/app/"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Runik AI",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["runik"]
      }
    }
  }
}
